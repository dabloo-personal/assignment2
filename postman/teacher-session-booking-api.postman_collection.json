{
  "info": {
    "name": "Teacher Session Booking API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"1234567890\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": ["{{baseUrl}}"],
          "path": ["users"]
        }
      }
    },
    {
      "name": "Create Teacher",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Dr. Smith\",\n  \"email\": \"smith@example.com\",\n  \"specialization\": \"Mathematics\",\n  \"experience\": 8\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/teachers",
          "host": ["{{baseUrl}}"],
          "path": ["teachers"]
        }
      }
    },
    {
      "name": "Create Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"teacherId\": \"{{teacherId}}\",\n  \"startTime\": \"2026-07-02T10:00:00.000Z\",\n  \"endTime\": \"2026-07-02T11:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/sessions",
          "host": ["{{baseUrl}}"],
          "path": ["sessions"]
        }
      }
    },
    {
      "name": "List Available Sessions",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/sessions/available?dateTimestamp=1770000000000",
          "host": ["{{baseUrl}}"],
          "path": ["sessions", "available"],
          "query": [
            {
              "key": "dateTimestamp",
              "value": "1770000000000"
            }
          ]
        }
      }
    },
    {
      "name": "Book Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/sessions/{{sessionId}}/book",
          "host": ["{{baseUrl}}"],
          "path": ["sessions", "{{sessionId}}", "book"]
        }
      }
    },
    {
      "name": "Complete Session",
      "request": {
        "method": "PATCH",
        "url": {
          "raw": "{{baseUrl}}/sessions/{{sessionId}}/complete",
          "host": ["{{baseUrl}}"],
          "path": ["sessions", "{{sessionId}}", "complete"]
        }
      }
    },
    {
      "name": "Get User Sessions",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/users/{{userId}}/sessions",
          "host": ["{{baseUrl}}"],
          "path": ["users", "{{userId}}", "sessions"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "teacherId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "sessionId",
      "value": ""
    }
  ]
}
