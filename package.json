{
  "name": "teacher-session-booking-api",
  "version": "1.0.0",
  "description": "REST API for booking teacher sessions with MongoDB and Mongoose",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "mongodb",
    "mongoose"
  ],
  "author": "Dabloo",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^22.10.1",
    "dotenv": "^16.4.1",
    "express": "^4.19.2",
    "mongoose": "^8.6.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
